<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ak_ze_input_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/ak_ze_tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="💰 Wealth Input"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/montserrat_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/ak_ze_tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter your monthly financial data"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/ak_ze_tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Income Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/ak_ze_card_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/ak_ze_tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/ak_ze_tv_income_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Monthly Income"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/accent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/ak_ze_til_income"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="0.00"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/accent"
                app:hintTextColor="@color/text_secondary"
                app:prefixText="₾ "
                app:layout_constraintTop_toBottomOf="@id/ak_ze_tv_income_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/ak_ze_et_income"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

            </com.google.android.material.textfield.TextInputLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Expenses Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/ak_ze_card_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/ak_ze_card_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/ak_ze_tv_expenses_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📉 Monthly Expenses"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/danger"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/ak_ze_til_expenses"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="0.00"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/danger"
                app:hintTextColor="@color/text_secondary"
                app:prefixText="₾ "
                app:layout_constraintTop_toBottomOf="@id/ak_ze_tv_expenses_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/ak_ze_et_expenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

            </com.google.android.material.textfield.TextInputLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/ak_ze_btn_save"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="CALCULATE &amp; SAVE"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:backgroundTint="@color/accent"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/ak_ze_card_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />


    <TextView
        android:id="@+id/ak_ze_tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/success"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/ak_ze_btn_save"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>